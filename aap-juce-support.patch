+
+# begin JUCEAAP specific -->
+# It is not beautiful, but there does not seem to be any way to add custom include directory for modules.
+include_directories(
+        "${AAP_DIR}/include"
+)
+
+juce_add_module(${AAP_JUCE_DIR}/aap-modules/aap_audio_processors)
+
